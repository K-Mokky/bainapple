# ---------------------------------------------------------------------------
# 바인애플 (Supabase edition) — copy this file to `.env` and fill in the blanks.
# ---------------------------------------------------------------------------

# --- Supabase project ------------------------------------------------------
SUPABASE_URL=https://fkfzxbvolgjbnjqzlerf.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_J3mo6BSdT6LNBmJXZtCuHw_xTTUOI-O

# --- Database connection (REQUIRED to actually use Supabase) ---------------
# Get this from: Supabase Dashboard -> Project Settings -> Database ->
# "Connection string" -> URI, then replace [YOUR-PASSWORD] with your DB password.
#
# Session pooler (IPv4, recommended for most machines):
#   DATABASE_URL=postgresql://postgres.fkfzxbvolgjbnjqzlerf:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# Direct connection (IPv6):
#   DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.fkfzxbvolgjbnjqzlerf.supabase.co:5432/postgres
DATABASE_URL=

# --- Flask secrets ---------------------------------------------------------
# Generate one:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-64-char-random-hex

# --- Session / cookie hardening --------------------------------------------
SESSION_COOKIE_SECURE=0
SESSION_LIFETIME_SECONDS=3600

# --- Server bind -----------------------------------------------------------
HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=0

# --- Uploads ---------------------------------------------------------------
MAX_UPLOAD_BYTES=3145728

# --- Moderation / throttling -----------------------------------------------
REPORT_BLOCK_THRESHOLD=3
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=300
CHAT_MAX_MESSAGES=10
CHAT_WINDOW_SECONDS=10
CHAT_MAX_LENGTH=500

# --- Seed admin (created on first run if both are set) ----------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# --- Admin key file --------------------------------------------------------
ADMIN_KEY_FILE=instance/admin_key.txt
